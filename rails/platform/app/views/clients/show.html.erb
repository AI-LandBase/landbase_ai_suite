<% content_for(:title) { @client.name } %>

<div class="w-full max-w-4xl mx-auto px-4">
  <%= render "shared/card", class: "mb-8" do %>
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-100"><%= @client.name %></h1>
        <p class="text-sm font-mono text-gray-400 mt-1"><%= @client.code %></p>
      </div>
      <div class="flex items-center gap-3">
        <% if @client.industry_codes.any? %>
          <span class="text-sm text-gray-400"><%= @client.industry_codes.map { |c| Client::INDUSTRY_LABELS[c] }.compact.join(" / ") %></span>
        <% end %>
        <% if @client.status == "active" %>
          <%= render "shared/badge", label: @client.status_label, variant: :success, size: :md %>
        <% elsif @client.status == "trial" %>
          <%= render "shared/badge", label: @client.status_label, variant: :info, size: :md %>
        <% end %>
        <%= render "shared/button", label: "編集", href: edit_client_path(@client), variant: :secondary, size: :sm, class: "text-sm" %>
        <% if @client.status != "inactive" %>
          <%= button_to "無効化", client_path(@client), method: :delete,
                form: { data: { turbo_confirm: "「#{@client.name}」を無効化しますか？この操作によりクライアントは一覧から非表示になります。" } },
                class: "bg-red-600 text-white px-3 py-1.5 rounded-md hover:bg-red-700 transition-colors text-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= render "shared/card", href: journal_entries_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">仕訳台帳</h2>
      <p class="text-sm text-gray-400">仕訳データの一覧表示・編集・CSVエクスポート</p>
    <% end %>

    <%= render "shared/card", href: new_amex_statement_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">Amex明細処理</h2>
      <p class="text-sm text-gray-400">Amex利用明細PDFをAIで仕訳データに変換</p>
    <% end %>

    <%= render "shared/card", href: new_bank_statement_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">銀行明細処理</h2>
      <p class="text-sm text-gray-400">銀行入出金明細PDFをAIで仕訳データに変換</p>
    <% end %>

    <%= render "shared/card", href: new_invoice_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">請求書処理</h2>
      <p class="text-sm text-gray-400">請求書PDFをAIで仕訳データに変換</p>
    <% end %>

    <%= render "shared/card", href: new_receipt_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">領収書処理</h2>
      <p class="text-sm text-gray-400">領収書・レシート画像をAIで仕訳データに変換（複数同時可）</p>
    <% end %>

    <% if @client.feature_available?(:cleaning_manuals) %>
    <%= render "shared/card", href: cleaning_manuals_path(client_code: @client.code), hover: true do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-2">清掃マニュアル</h2>
      <p class="text-sm text-gray-400">AI生成の清掃基準マニュアル管理</p>
    <% end %>
    <% end %>
  </div>

  <%# クレカマスタ管理 %>
  <div class="mt-8">
    <%= render "shared/card" do %>
      <h2 class="text-lg font-semibold text-gray-100 mb-4">クレジットカードマスタ</h2>
      <p class="text-sm text-gray-400 mb-4">登録したカード末尾と一致する領収書仕訳に赤ラベルで警告表示します（AMEX明細との重複判断用）。</p>

      <% cards = @client.payment_cards.order(:last_four) %>
      <% if cards.any? %>
        <ul class="space-y-2 mb-4">
          <% cards.each do |card| %>
            <li class="flex items-center justify-between py-2 px-3 bg-gray-800 rounded-md">
              <div>
                <span class="font-mono text-gray-100">****<%= card.last_four %></span>
                <% if card.card_name.present? %>
                  <span class="ml-2 text-sm text-gray-400">(<%= card.card_name %>)</span>
                <% end %>
              </div>
              <%= button_to "削除",
                    client_payment_card_path(@client, card),
                    method: :delete,
                    form: { data: { turbo_confirm: "末尾#{card.last_four}のカードを削除しますか？" } },
                    class: "text-red-400 hover:text-red-300 text-sm bg-transparent border-0 p-0 cursor-pointer" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500 mb-4">登録済みカードはありません。</p>
      <% end %>

      <%= form_with url: client_payment_cards_path(@client), method: :post, class: "flex items-end gap-3 flex-wrap" do |f| %>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">末尾4桁 <span class="text-red-400">*</span></label>
          <%= f.text_field :last_four,
                name: "payment_card[last_four]",
                placeholder: "例: 1234",
                maxlength: 4,
                class: "w-24 rounded-md bg-gray-800 border-gray-600 text-gray-100 px-3 py-2 text-sm focus:border-teal-500 focus:ring-teal-500" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">ラベル（任意）</label>
          <%= f.text_field :card_name,
                name: "payment_card[card_name]",
                placeholder: "例: 法人AMEX",
                maxlength: 50,
                class: "w-40 rounded-md bg-gray-800 border-gray-600 text-gray-100 px-3 py-2 text-sm focus:border-teal-500 focus:ring-teal-500" %>
        </div>
        <%= f.submit "追加",
              class: "px-4 py-2 bg-teal-600 text-white text-sm rounded-md hover:bg-teal-700 transition-colors cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
</div>
