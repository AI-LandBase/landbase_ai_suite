# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log
*.tmp

# Environment variables
# .env.development は Git 管理（開発設定）
# .env.production は Git 管理（テンプレート値、VPS上で本番値に書き換え）
.env.local

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/

# Production storage (compose.production.yaml が ./storage を bind mount する。
# クライアントの PDF/画像が乗るため、誤って git add しないよう丸ごと無視する)
/storage/

# Node modules and build artifacts
node_modules/
/rails/*/app/assets/builds/*
!/rails/*/app/assets/builds/.keep

# Yarn Berry (Yarn 2+)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
